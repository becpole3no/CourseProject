<Window
    x:Class="CourseProject.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title=""
    mc:Ignorable="d">

    <Grid Background="#F5F5F7">
        <Grid.Resources>
            <x:Double x:Key="ProgressBarTrackHeight">11</x:Double>
            <CornerRadius x:Key="ProgressBarTrackCornerRadius">5.5</CornerRadius>

            <Style x:Key="SurfaceCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="BorderBrush" Value="#50D2D2D7" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
            </Style>

            <Style x:Key="SoftPanelStyle" TargetType="Border">
                <Setter Property="Background" Value="#F5F5F7" />
                <Setter Property="CornerRadius" Value="10" />
            </Style>

            <Style x:Key="InfoCardStyle" TargetType="Border">
                <Setter Property="BorderBrush" Value="#D2D2D7" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
            </Style>

            <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="/Resources/Fonts/#SF Pro Display" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="#1D1D1F" />
            </Style>

            <Style x:Key="FieldTitleTextStyle" TargetType="TextBlock">
                <Setter Property="CharacterSpacing" Value="20" />
                <Setter Property="FontFamily" Value="/Resources/Fonts/#SF Pro Display" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Foreground" Value="#1D1D1F" />
            </Style>

            <Style x:Key="BodyTextStyle" TargetType="TextBlock">
                <Setter Property="CharacterSpacing" Value="28" />
                <Setter Property="FontFamily" Value="/Resources/Fonts/#SF Pro Display" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="Light" />
                <Setter Property="Foreground" Value="#1D1D1F" />
            </Style>

            <Style x:Key="FloatingTextBoxStyle" TargetType="TextBox">
                <Setter Property="Background" Value="#F5F5F7" />
                <Setter Property="BorderBrush" Value="#D2D2D7" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CharacterSpacing" Value="28" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Foreground" Value="#1D1D1F" />
                <Setter Property="FontFamily" Value="/Resources/Fonts/#SF Pro Display" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="Light" />
                <Setter Property="Padding" Value="14,9,14,0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Grid>
                                <Border
                                    x:Name="BorderElement"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}" />

                                <ScrollViewer
                                    x:Name="ContentElement"
                                    Margin="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    AutomationProperties.AccessibilityView="Raw"
                                    Foreground="{TemplateBinding Foreground}"
                                    HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                    HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}"
                                    IsDeferredScrollingEnabled="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                                    IsTabStop="False"
                                    VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                    VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}"
                                    ZoomMode="Disabled" />

                                <TextBlock
                                    x:Name="FloatingLabel"
                                    Margin="15,9,14,9"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    CharacterSpacing="28"
                                    FontFamily="{TemplateBinding FontFamily}"
                                    FontSize="{TemplateBinding FontSize}"
                                    FontWeight="{TemplateBinding FontWeight}"
                                    Foreground="#757575"
                                    IsHitTestVisible="False"
                                    RenderTransformOrigin="0,0.5"
                                    Text="{TemplateBinding PlaceholderText}"
                                    TextTrimming="CharacterEllipsis">
                                    <TextBlock.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="FloatingLabelScaleTransform" />
                                            <TranslateTransform x:Name="FloatingLabelTranslateTransform" />
                                        </TransformGroup>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="BorderElement.BorderBrush" Value="#D2D2D7" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Focused">
                                            <VisualState.Setters>
                                                <Setter Target="BorderElement.BorderBrush" Value="#0071E3" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="BorderElement.Opacity" Value="0.6" />
                                                <Setter Target="FloatingLabel.Opacity" Value="0.6" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>

                                    <VisualStateGroup x:Name="LabelStates">
                                        <VisualState x:Name="Resting">
                                            <VisualState.Setters>
                                                <Setter Target="ContentElement.Padding" Value="14,9,14,9" />
                                            </VisualState.Setters>
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="FloatingLabelScaleTransform"
                                                    Storyboard.TargetProperty="ScaleX"
                                                    To="1"
                                                    Duration="0:0:0.10" />
                                                <DoubleAnimation
                                                    Storyboard.TargetName="FloatingLabelScaleTransform"
                                                    Storyboard.TargetProperty="ScaleY"
                                                    To="1"
                                                    Duration="0:0:0.10" />
                                                <DoubleAnimation
                                                    Storyboard.TargetName="FloatingLabelTranslateTransform"
                                                    Storyboard.TargetProperty="Y"
                                                    To="0"
                                                    Duration="0:0:0.10" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Floating">
                                            <VisualState.Setters>
                                                <Setter Target="ContentElement.Padding" Value="14,17,14,0" />
                                            </VisualState.Setters>
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="FloatingLabelScaleTransform"
                                                    Storyboard.TargetProperty="ScaleX"
                                                    To="0.86"
                                                    Duration="0:0:0.10" />
                                                <DoubleAnimation
                                                    Storyboard.TargetName="FloatingLabelScaleTransform"
                                                    Storyboard.TargetProperty="ScaleY"
                                                    To="0.86"
                                                    Duration="0:0:0.10" />
                                                <DoubleAnimation
                                                    Storyboard.TargetName="FloatingLabelTranslateTransform"
                                                    Storyboard.TargetProperty="Y"
                                                    To="-7"
                                                    Duration="0:0:0.10" />
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CourseComboBoxItemStyle" TargetType="ComboBoxItem">
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="Foreground" Value="#1D1D1F" />
                <Setter Property="FontFamily" Value="/Resources/Fonts/#SF Pro Display" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="Light" />
                <Setter Property="Padding" Value="12,10,12,10" />
            </Style>

            <Style x:Key="CourseComboBoxStyle" TargetType="ComboBox">
                <Setter Property="Background" Value="#F5F5F7" />
                <Setter Property="BorderBrush" Value="#D2D2D7" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Foreground" Value="#1D1D1F" />
                <Setter Property="FontFamily" Value="/Resources/Fonts/#SF Pro Display" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="Light" />
                <Setter Property="Padding" Value="14,0,14,0" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="ItemContainerStyle" Value="{StaticResource CourseComboBoxItemStyle}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid x:Name="LayoutRoot">
                                <Border
                                    x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                    <Grid>
                                        <ContentPresenter
                                            x:Name="ContentPresenter"
                                            Margin="14,0,36,1"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                            Content="{TemplateBinding SelectionBoxItem}"
                                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                            Foreground="{TemplateBinding Foreground}" />

                                        <FontIcon
                                            x:Name="ChevronIcon"
                                            Margin="0,0,14,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="12"
                                            Foreground="#757575"
                                            Glyph="&#xE70D;" />
                                    </Grid>
                                </Border>

                                <Popup
                                    x:Name="Popup"
                                    IsLightDismissEnabled="True"
                                    IsOpen="{TemplateBinding IsDropDownOpen}">
                                    <Border
                                        Width="{Binding ActualWidth, ElementName=LayoutRoot}"
                                        Margin="0,4,0,0"
                                        Background="#FFFFFF"
                                        BorderBrush="#D2D2D7"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <ScrollViewer MaxHeight="320">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="ComboBorder.BorderBrush" Value="#D2D2D7" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed" />
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="LayoutRoot.Opacity" Value="0.6" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>

                                    <VisualStateGroup x:Name="DropDownStates">
                                        <VisualState x:Name="Closed">
                                            <VisualState.Setters>
                                                <Setter Target="ComboBorder.BorderBrush" Value="#D2D2D7" />
                                                <Setter Target="ChevronIcon.Glyph" Value="&#xE70D;" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Opened">
                                            <VisualState.Setters>
                                                <Setter Target="ComboBorder.BorderBrush" Value="#0071E3" />
                                                <Setter Target="ChevronIcon.Glyph" Value="&#xE70E;" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CourseProgressBarStyle" TargetType="ProgressBar">
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="Foreground" Value="#0071E3" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Minimum" Value="0" />
                <Setter Property="Maximum" Value="100" />
                <Setter Property="MinHeight" Value="11" />
                <Setter Property="CornerRadius" Value="6" />
            </Style>

            <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid">
                                <Border x:Name="ButtonBorder" CornerRadius="20">
                                    <Border.Background>
                                        <SolidColorBrush Color="#0071E3" />
                                    </Border.Background>
                                    <TextBlock
                                        Margin="0,0,0,3"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        CharacterSpacing="28"
                                        FontFamily="/Resources/Fonts/#SF Pro Display"
                                        FontSize="14"
                                        FontWeight="Light"
                                        Foreground="White"
                                        Text="{TemplateBinding Content}" />
                                </Border>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <VisualState.Setters>
                                                <Setter Target="ButtonBorder.Background" Value="#0071E3" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="ButtonBorder.Background" Value="#1E81E5" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="ButtonBorder.Background" Value="#1E81E5" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="ButtonBorder.Opacity" Value="0.5" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid">
                                <Border
                                    x:Name="ButtonBorder"
                                    BorderBrush="#0071E3"
                                    BorderThickness="1"
                                    CornerRadius="20">
                                    <Border.Background>
                                        <SolidColorBrush Color="#FFFFFF" />
                                    </Border.Background>
                                    <TextBlock
                                        Margin="0,0,0,3"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        CharacterSpacing="28"
                                        FontFamily="/Resources/Fonts/#SF Pro Display"
                                        FontSize="14"
                                        FontWeight="Light"
                                        Foreground="#0071E3"
                                        Text="{TemplateBinding Content}" />
                                </Border>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <VisualState.Setters>
                                                <Setter Target="ButtonBorder.Background" Value="#FFFFFF" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="ButtonBorder.Background" Value="#F0F7FD" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="ButtonBorder.Background" Value="#F0F7FD" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="ButtonBorder.Opacity" Value="0.5" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DarkActionButtonStyle" TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid">
                                <Border x:Name="ButtonBorder" CornerRadius="8">
                                    <Border.Background>
                                        <SolidColorBrush Color="#1D1D1F" />
                                    </Border.Background>
                                    <TextBlock
                                        Margin="0,0,0,3"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        CharacterSpacing="28"
                                        FontFamily="/Resources/Fonts/#SF Pro Display"
                                        FontSize="14"
                                        FontWeight="Light"
                                        Foreground="White"
                                        Text="{TemplateBinding Content}" />
                                </Border>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <VisualState.Setters>
                                                <Setter Target="ButtonBorder.Background" Value="#1D1D1F" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="ButtonBorder.Background" Value="#1D1D1F" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="ButtonBorder.Background" Value="#1D1D1F" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="ButtonBorder.Opacity" Value="0.5" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="53" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Background="#F5F5F7" />

        <Border
            Grid.Row="1"
            Width="542"
            Height="291"
            Margin="31,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Style="{StaticResource SurfaceCardStyle}">

            <Grid>

                <TextBlock
                    Margin="19,22,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Style="{StaticResource SectionTitleTextStyle}"
                    Text="Исходные данные" />

                <TextBlock
                    Margin="19,58,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    CharacterSpacing="20"
                    FontFamily="/Resources/Fonts/#SF Pro Display"
                    FontSize="14"
                    FontWeight="Light"
                    Foreground="#1D1D1F"
                    Text="Массив чисел" />

                <TextBox
                    x:Name="InputArrayTextBox"
                    Width="504"
                    Height="128"
                    Margin="19,87,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    GotFocus="FloatingTextBox_StateChanged"
                    LostFocus="FloatingTextBox_StateChanged"
                    PlaceholderText="Введите элементы массива"
                    Style="{StaticResource FloatingTextBoxStyle}"
                    TextChanged="FloatingTextBox_TextChanged"
                    TextWrapping="Wrap" />

                <TextBox
                    x:Name="ArraySizeTextBox"
                    Width="157"
                    Height="38"
                    Margin="19,233,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    GotFocus="FloatingTextBox_StateChanged"
                    LostFocus="FloatingTextBox_StateChanged"
                    PlaceholderText="Размер массива"
                    Style="{StaticResource FloatingTextBoxStyle}"
                    TextChanged="FloatingTextBox_TextChanged" />

                <Button
                    Width="138"
                    Height="37"
                    Margin="191,233,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Click="GenerateArrayButton_Click"
                    Content="Сгенерировать"
                    PointerEntered="Button_PointerEntered"
                    PointerExited="Button_PointerExited"
                    Style="{StaticResource PrimaryActionButtonStyle}" />

                <Button
                    Width="101"
                    Height="37"
                    Margin="344,233,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Click="ClearButton_Click"
                    Content="Очистить"
                    PointerEntered="Button_PointerEntered"
                    PointerExited="Button_PointerExited"
                    Style="{StaticResource SecondaryActionButtonStyle}" />

            </Grid>

        </Border>

        <Border
            Grid.Row="1"
            Width="400"
            Height="291"
            Margin="591,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Style="{StaticResource SurfaceCardStyle}">

            <Grid>

                <TextBlock
                    Margin="19,22,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Style="{StaticResource SectionTitleTextStyle}"
                    Text="Быстрые метрики" />

                <Border
                    Width="38"
                    Height="19"
                    Margin="340,23,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#F5F5F7"
                    CornerRadius="10">

                    <TextBlock
                        Margin="0,0,0,2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        CharacterSpacing="28"
                        FontFamily="/Resources/Fonts/#SF Pro Display"
                        FontSize="11"
                        FontWeight="Light"
                        Foreground="#1D1D1F"
                        Text="Live" />

                </Border>

                <Border
                    Width="174"
                    Height="73"
                    Margin="19,58,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Style="{StaticResource SoftPanelStyle}">

                    <Grid>

                        <TextBlock
                            Margin="11,14,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            CharacterSpacing="28"
                            FontFamily="/Resources/Fonts/#SF Pro Display"
                            FontSize="12"
                            FontWeight="Light"
                            Foreground="#1D1D1F"
                            Text="Статистика" />

                        <TextBlock
                            x:Name="MetricElementCountText"
                            Margin="11,39,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            FontFamily="/Resources/Fonts/#SF Pro Display"
                            FontSize="18"
                            FontWeight="Medium"
                            Foreground="#1D1D1F"
                            Text="0" />

                    </Grid>

                </Border>

                <Border
                    Width="174"
                    Height="73"
                    Margin="205,58,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Style="{StaticResource SoftPanelStyle}">

                    <Grid>

                        <TextBlock
                            Margin="11,14,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            CharacterSpacing="28"
                            FontFamily="/Resources/Fonts/#SF Pro Display"
                            FontSize="12"
                            FontWeight="Light"
                            Foreground="#1D1D1F"
                            Text="Сортировка" />

                        <TextBlock
                            x:Name="MetricSortComplexityText"
                            Margin="11,39,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            FontFamily="/Resources/Fonts/#SF Pro Display"
                            FontSize="18"
                            FontWeight="Medium"
                            Foreground="#1D1D1F"
                            Text="-" />

                    </Grid>

                </Border>

                <Border
                    Width="174"
                    Height="73"
                    Margin="19,142,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Style="{StaticResource SoftPanelStyle}">

                    <Grid>

                        <TextBlock
                            Margin="11,13,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            CharacterSpacing="28"
                            FontFamily="/Resources/Fonts/#SF Pro Display"
                            FontSize="12"
                            FontWeight="Light"
                            Foreground="#1D1D1F"
                            Text="Поиск" />

                        <TextBlock
                            x:Name="MetricSearchComplexityText"
                            Margin="11,38,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            FontFamily="/Resources/Fonts/#SF Pro Display"
                            FontSize="18"
                            FontWeight="Medium"
                            Foreground="#1D1D1F"
                            Text="-" />

                    </Grid>

                </Border>

                <Border
                    Width="174"
                    Height="73"
                    Margin="204,142,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Style="{StaticResource SoftPanelStyle}">

                    <Grid>

                        <TextBlock
                            Margin="13,13,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            CharacterSpacing="28"
                            FontFamily="/Resources/Fonts/#SF Pro Display"
                            FontSize="12"
                            FontWeight="Light"
                            Foreground="#1D1D1F"
                            Text="Сравнений" />

                        <TextBlock
                            x:Name="MetricComparisonCountText"
                            Margin="13,38,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            FontFamily="/Resources/Fonts/#SF Pro Display"
                            FontSize="18"
                            FontWeight="Medium"
                            Foreground="#1D1D1F"
                            Text="0" />

                    </Grid>

                </Border>

            </Grid>

        </Border>

        <Border
            Grid.Row="1"
            Width="423"
            Height="188"
            Margin="31,308,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Style="{StaticResource SurfaceCardStyle}">

            <Grid>

                <TextBlock
                    Margin="19,22,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Style="{StaticResource SectionTitleTextStyle}"
                    Text="Сортировка" />

                <TextBlock
                    Margin="19,60,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Style="{StaticResource FieldTitleTextStyle}"
                    Text="Алгоритм сортировки" />

                <ComboBox
                    x:Name="SortAlgorithmComboBox"
                    Width="385"
